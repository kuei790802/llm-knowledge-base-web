# Required: Absolute path to your Obsidian vault
VAULT_PATH=/Users/yourname/Documents/ObsidianVault

# Optional: Default domain to show on startup
DEFAULT_DOMAIN=Anthropic
NEXT_PUBLIC_DEFAULT_DOMAIN=Anthropic

# Optional: Access token for Cloudflare tunnel security
# Leave blank for local-only use
ACCESS_TOKEN=

# Optional: Port (default 3000)
PORT=3000

# Optional: Default CLI provider (claude, codex, gemini)
CLI_PROVIDER=claude
NEXT_PUBLIC_CLI_PROVIDER=claude

# Optional: API keys for CLI providers that support them
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Optional: Path to claude CLI (default: "claude" from PATH)
# CLAUDE_PATH=/usr/local/bin/claude
