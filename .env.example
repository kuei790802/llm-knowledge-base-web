# Required: Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Required: Absolute path to your Obsidian vault
VAULT_PATH=/Users/yourname/Documents/ObsidianVault

# Optional: Default domain to show on startup
DEFAULT_DOMAIN=Anthropic
NEXT_PUBLIC_DEFAULT_DOMAIN=Anthropic

# Optional: Access token for Cloudflare tunnel security
# Leave blank to disable token check (local-only use is fine without it)
ACCESS_TOKEN=

# Optional: Port (default 3000)
PORT=3000
